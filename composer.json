{
  "name": "dev-3bdulrahman/purchases",
  "description": "A Purchases module for Laravel ERP — purchase requests, orders, invoices, returns, suppliers & payments.",
  "type": "library",
  "version": "1.0.0",
  "license": "MIT",
  "authors": [
    {
      "name": "Abdulrahman",
      "homepage": "https://3bdulrahman.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2|^8.3",
    "laravel/framework": "^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Dev3bdulrahman\\Purchases\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Dev3bdulrahman\\Purchases\\PurchasesServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
